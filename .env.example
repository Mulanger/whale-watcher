NODE_ENV=development
LOG_LEVEL=info

# Polymarket
POLYMARKET_DATA_URL=https://data-api.polymarket.com
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com

# Polling
POLL_INTERVAL_MS=3000
WHALE_USD_FLOOR=10000
TRADES_PAGE_LIMIT=500
DATA_API_STALE_AFTER_MS=900000

# Mongo
MONGO_URI=mongodb://localhost:27017/polywatch
MONGO_DB=polywatch

# Redis
REDIS_URL=redis://localhost:6379
REDIS_CHANNEL=whales
INTENT_CLASSIFICATION_ENABLED=false
TRADE_EVENTS_ENABLED=false
TRADE_EVENTS_USD_FLOOR=1000
ALL_TRADES_INTERVAL_MS=30000
TRADE_EVENTS_PAGE_LIMIT=1000
DAILY_AGGREGATOR_INTERVAL_MS=300000

# Health
HEALTH_PORT=8080
